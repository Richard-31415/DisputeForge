# Model providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Which model provider to use for the agent: "anthropic" or "openai"
# openai: uses gpt-4o-mini (communicator) + gpt-4o (planner/explainer)
# anthropic: uses claude-haiku-4-5 (communicator) + claude-sonnet-4-6 (planner/explainer)
AGENT_MODEL_PROVIDER=openai

# Retrieval
LLAMA_CLOUD_API_KEY=llx-...

# Observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# LangGraph / LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=disputeforge

# Demo mode flags
DEMO_MODE=false            # true = deterministic seeds, cached responses
DEMO_FAIL_INJECTION=false  # true = inject flaky tool for the rollback moment
